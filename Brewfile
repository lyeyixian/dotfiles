# Brewfile — core tools and fonts for these dotfiles.
# Install everything at once with:  brew bundle --file ~/.dotfiles/Brewfile

# Core CLI tools
brew "stow"     # symlink manager that wires these packages into $HOME
brew "git"
brew "tmux"
brew "neovim"

# Fonts — Nerd Font supplies the glyphs used by Powerlevel10k, LazyVim and the
# tmux status bar. Without it those icons render as "?" or boxes.
# After installing, set your terminal font to "MesloLGS Nerd Font Mono".
cask "font-meslo-lg-nerd-font"
