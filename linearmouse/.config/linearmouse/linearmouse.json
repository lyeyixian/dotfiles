{
  "$schema" : "https:\/\/schema.linearmouse.app\/0.10.4",
  "schemes" : [
    {
      "if" : {
        "device" : {
          "category" : "mouse",
          "productID" : "0x82",
          "productName" : "Basilisk X HyperSpeed",
          "vendorID" : "0x1532"
        }
      },
      "pointer" : {
        "acceleration" : 1,
        "disableAcceleration" : true
      },
      "scrolling" : {
        "acceleration" : {
          "vertical" : 1
        },
        "distance" : {
          "vertical" : "auto"
        },
        "reverse" : {
          "vertical" : true
        },
        "speed" : {
          "vertical" : 10
        }
      }
    }
  ]
}